---
const built = new Date().toISOString().slice(0, 10);
const base = (import.meta.env.BASE_URL ?? "/").replace(/\/$/, "");
const repo = "https://github.com/lizeman/llm-arch-kb";
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <p>
      Content licensed <a href="https://creativecommons.org/licenses/by/4.0/" rel="license">CC&nbsp;BY&nbsp;4.0</a>.
      Code licensed <a href={`${repo}/blob/main/LICENSE`}>MIT</a>.
    </p>
    <p>
      <a href={repo}>Source on GitHub</a>
      &nbsp;·&nbsp;
      <a href={`${base}/about/`}>Methodology</a>
      &nbsp;·&nbsp;
      Last built {built}
    </p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    margin-top: 96px;
    padding: 40px 24px 64px;
    color: var(--text-soft);
    font-size: var(--t-small);
  }
  .site-footer__inner {
    max-width: 880px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }
  .site-footer p { margin: 0; }
  .site-footer a { color: var(--text-soft); }
  .site-footer a:hover { color: var(--accent); }
</style>
