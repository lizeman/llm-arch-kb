---
import { getCollection } from "astro:content";
import { BASE, slugTail } from "~/utils/site";

interface Props {
  slug: string;
  category: string;
}

const { slug, category } = Astro.props;

const all = await getCollection("techniques");
const current = all.find((t) => slugTail(t.slug) === slug && t.data.category === category);

type Related = {
  slug: string;
  title: string;
  abbreviation: string;
  category: string;
  year: number;
  status: string;
  hook: string;
  adopters: number;
  score: number;
};

const related: Related[] = [];

if (current) {
  const currentYear = current.data.year;
  const currentAdopters = new Set(
    (current.data.adopted_by ?? []).map((a: { model: string }) => a.model),
  );

  for (const t of all) {
    if (t.slug === current.slug) continue;
    const tail = slugTail(t.slug);

    let score = 0;
    // (a) same category, year within ±2
    if (t.data.category === current.data.category) {
      const dy = Math.abs(t.data.year - currentYear);
      if (dy <= 2) score += 3 - Math.min(dy, 2); // 3 / 2 / 1
    }
    // (b) shared adopter overlap
    const overlap = (t.data.adopted_by ?? []).reduce(
      (acc: number, a: { model: string }) => acc + (currentAdopters.has(a.model) ? 1 : 0),
      0,
    );
    score += overlap;

    if (score > 0) {
      related.push({
        slug: tail,
        title: t.data.title,
        abbreviation: t.data.abbreviation,
        category: t.data.category,
        year: t.data.year,
        status: t.data.status,
        // problem_solved is the editorial hook; fall back to summary
        // for entries that don't surface it.
        hook: t.data.problem_solved ?? t.data.summary,
        adopters: (t.data.adopted_by ?? []).length,
        score,
      });
    }
  }
}

related.sort((a, b) => b.score - a.score || a.title.localeCompare(b.title));
const top = related.slice(0, 5);
---

{top.length > 0 && (
  <section class="related">
    <p class="section-eyebrow">See also</p>
    <ul class="entry-row-list">
      {top.map((r) => (
        <li>
          <a href={`${BASE}/${r.category}/${r.slug}/`} class="entry-row">
            <div class="entry-row__title">
              <strong>{r.title}</strong>
              <span class="entry-row__abbr">{r.abbreviation}</span>
            </div>
            <p class="entry-row__hook">{r.hook}</p>
            <div class="entry-row__meta">
              <span>{r.year}</span>
              <span aria-hidden="true">·</span>
              <span>{r.status}</span>
              <span aria-hidden="true">·</span>
              <span><span class="entry-row__adopters">{r.adopters}</span> {r.adopters === 1 ? "adopter" : "adopters"}</span>
              <span class="entry-row__cta" aria-hidden="true">Read entry <span class="entry-row__chevron">→</span></span>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </section>
)}

<style>
  .related {
    margin: 40px 0 32px;
  }
  /* The list uses the shared .entry-row utility in global.css.
     Local rules just tighten the top border so the list reads as
     a single rhythmic block under the eyebrow. */
  .related .entry-row-list {
    margin-top: 8px;
    border-top: 1px solid var(--border);
  }
</style>
