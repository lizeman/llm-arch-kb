---
import { getCollection } from "astro:content";
import { mostSimilarModels } from "~/lib/similarity";
import { BASE } from "~/utils/site";

interface Props {
  slug: string;
}

const { slug } = Astro.props;

const allModels = await getCollection("models");
const lookup = new Map(allModels.map((m) => [m.slug, m.data]));
const allSlugs = allModels.map((m) => m.slug);

const similar = await mostSimilarModels(slug, allSlugs, 3);
---

{similar.length > 0 && (
  <section class="similar-models" aria-labelledby="similar-models-heading">
    <p class="section-eyebrow" id="similar-models-heading">Models like this</p>
    <ul>
      {similar.map((s) => {
        const data = lookup.get(s.slug);
        const name = data?.name ?? s.slug;
        const org = data?.organization;
        const pct = Math.round(s.similarity * 100);
        return (
          <li>
            <a href={`${BASE}/models/${s.slug}/`}>
              <span class="name">{name}</span>
              {org && <span class="org">{org}</span>}
            </a>
            <span class="overlap" title={`Jaccard similarity over shared technique adoptions: ${s.shared}/${s.union}`}>
              {pct}% overlap
            </span>
          </li>
        );
      })}
    </ul>
  </section>
)}

<style>
  .similar-models {
    margin: 56px 0 32px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
  }
  ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  li {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    padding: 10px 0;
    border-bottom: 1px solid var(--border);
    font-size: var(--t-small);
  }
  li:last-child { border-bottom: none; }
  li a {
    color: inherit;
    text-decoration: none;
    display: inline-flex;
    gap: 10px;
    align-items: baseline;
    flex: 1 1 auto;
    min-width: 0;
  }
  li a:hover .name { text-decoration: underline; }
  .name { font-weight: 500; }
  .org {
    color: var(--text-soft);
  }
  .overlap {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--text-faint);
    letter-spacing: 0.02em;
    white-space: nowrap;
  }
</style>
