---
import BaseLayout from "./BaseLayout.astro";
import { CATEGORY_LABELS } from "~/utils/adoption-graph";
import { isoMonth } from "~/utils/chronological-sort";
import { BASE, slugTail } from "~/utils/site";

interface Props {
  category: keyof typeof CATEGORY_LABELS;
  description: string;
  entries: {
    slug: string;
    data: {
      title: string;
      abbreviation: string;
      year: number;
      month?: number;
      summary: string;
      status: string;
      problem_solved?: string;
      adopted_by?: { model: string }[];
    };
  }[];
}

const { category, description, entries } = Astro.props;
const label = CATEGORY_LABELS[category];

const STATUS_FILTERS = [
  { key: "all", label: "All" },
  { key: "foundational", label: "Foundational" },
  { key: "production-adopted", label: "Production-adopted" },
  { key: "research", label: "Research" },
  { key: "deprecated", label: "Deprecated" },
] as const;

const counts: Record<string, number> = { all: entries.length };
for (const e of entries) {
  counts[e.data.status] = (counts[e.data.status] ?? 0) + 1;
}
---

<BaseLayout title={label} description={description}>
  <article class="prose">
    <header class="cat-header">
      <p class="section-eyebrow">Category</p>
      <h1>{label}</h1>
      <p class="lede">{description}</p>
    </header>

    {entries.length === 0 ? (
      <p class="empty">No entries yet — this category is on the v1 → v3 roadmap.</p>
    ) : (
      <div class="filter-shell" data-current="all">
        <fieldset class="filter-chips" aria-label="Filter by status">
          <legend class="visually-hidden">Filter by status</legend>
          {STATUS_FILTERS.map((f) => (
            <button
              type="button"
              class:list={["chip", { "is-active": f.key === "all" }]}
              data-filter={f.key}
              aria-pressed={f.key === "all" ? "true" : "false"}
            >
              <span class="chip-label">{f.label}</span>
              <span class="chip-count">{counts[f.key] ?? 0}</span>
            </button>
          ))}
        </fieldset>

        <ul class="entry-list entry-row-list">
          {entries.map((e) => {
            const adopters = (e.data.adopted_by ?? []).length;
            const hook = e.data.problem_solved ?? e.data.summary;
            return (
              <li data-status={e.data.status}>
                <a href={`${BASE}/${category}/${slugTail(e.slug)}/`} class="entry-row">
                  <div class="entry-row__title">
                    <strong>{e.data.title}</strong>
                    <span class="entry-row__abbr">{e.data.abbreviation}</span>
                    <span class:list={["status-pill", `status-${e.data.status}`]}>{e.data.status}</span>
                  </div>
                  <p class="entry-row__hook">{hook}</p>
                  <div class="entry-row__meta">
                    <span>{isoMonth(e.data.year, e.data.month)}</span>
                    <span aria-hidden="true">·</span>
                    <span>{e.data.status}</span>
                    <span aria-hidden="true">·</span>
                    <span><span class="entry-row__adopters">{adopters}</span> {adopters === 1 ? "adopter" : "adopters"}</span>
                    <span class="entry-row__cta" aria-hidden="true">Read entry <span class="entry-row__chevron">→</span></span>
                  </div>
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    )}
  </article>

  <script>
    const shell = document.querySelector<HTMLElement>(".filter-shell");
    if (shell) {
      const chips = shell.querySelectorAll<HTMLButtonElement>(".chip");
      const items = shell.querySelectorAll<HTMLElement>(".entry-list > li");
      chips.forEach((chip) => {
        chip.addEventListener("click", () => {
          const target = chip.dataset.filter ?? "all";
          shell.dataset.current = target;
          chips.forEach((c) => {
            const active = c.dataset.filter === target;
            c.classList.toggle("is-active", active);
            c.setAttribute("aria-pressed", active ? "true" : "false");
          });
          items.forEach((li) => {
            const status = li.dataset.status ?? "";
            const show = target === "all" || status === target;
            li.hidden = !show;
          });
        });
      });
    }
  </script>
</BaseLayout>

<style>
  .cat-header { margin: 48px 0 32px; }
  .cat-header h1 { margin: 8px 0 24px; }
  .lede {
    font-size: 1.125rem;
    color: var(--text-soft);
    line-height: 1.6;
  }
  .empty {
    color: var(--text-soft);
    font-style: italic;
    padding: 32px 0;
  }
  .filter-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    border: none;
    padding: 0;
    margin: 0 0 24px;
  }
  .chip {
    appearance: none;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 4px 12px;
    font-family: var(--serif);
    font-size: var(--t-small);
    color: var(--text-soft);
    cursor: pointer;
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
  }
  .chip:hover { color: var(--text); border-color: var(--text-faint); }
  .chip.is-active {
    color: var(--accent);
    border-color: var(--accent);
  }
  .chip-count {
    font-family: var(--mono);
    font-size: var(--t-chip-count);
    color: var(--text-faint);
  }
  .chip.is-active .chip-count { color: var(--accent); }
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  /* Entry list uses the shared .entry-row utility in global.css.
     Local rules here just position the status pill and reset margins. */
  .entry-list.entry-row-list { margin-top: 0; }
  .status-pill {
    font-family: var(--mono);
    font-size: var(--t-pill);
    letter-spacing: 0.04em;
    color: var(--text-faint);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 2px 9px;
    margin-left: auto;
  }
</style>
