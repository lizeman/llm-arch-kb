---
import BaseLayout from "./BaseLayout.astro";
import AdoptionList from "~/components/AdoptionList.astro";
import Lineage from "~/components/Lineage.astro";
import Cite from "~/components/Cite.astro";
import { CATEGORY_LABELS } from "~/utils/adoption-graph";
import { monthName } from "~/utils/chronological-sort";
import { BASE } from "~/utils/site";

interface Props {
  frontmatter: {
    title: string;
    abbreviation: string;
    category: keyof typeof CATEGORY_LABELS;
    year: number;
    month?: number;
    introduced_by: string;
    paper_title: string;
    arxiv_id: string;
    paper_url: string;
    status: string;
    problem_solved: string;
    summary: string;
    adopted_by: { model: string; source_url: string; notes?: string }[];
    predecessors?: string[];
    successors?: string[];
    prerequisites?: string[];
    difficulty?: 'intro' | 'intermediate' | 'advanced';
    facets?: string[];
    last_verified: string;
  };
}

const { frontmatter } = Astro.props;
const month = monthName(frontmatter.month, "long");
const date = month ? `${month} ${frontmatter.year}` : `${frontmatter.year}`;
---

<BaseLayout title={`${frontmatter.title} (${frontmatter.abbreviation})`} description={frontmatter.summary}>
  <article class="prose">
    <header class="entry-header">
      <p class="section-eyebrow">
        <a href={`${BASE}/${frontmatter.category}/`}>{CATEGORY_LABELS[frontmatter.category]}</a>
        &nbsp;·&nbsp;{date}
      </p>
      <h1>{frontmatter.title}</h1>
      {frontmatter.difficulty && (
        <p class="entry-difficulty">{frontmatter.difficulty}</p>
      )}
      <p class="entry-meta">
        Introduced by <strong>{frontmatter.introduced_by}</strong> in
        &nbsp;<a href={frontmatter.paper_url} rel="noopener noreferrer"><cite>{frontmatter.paper_title}</cite></a>
        &nbsp;(<span class="arxiv">arXiv:{frontmatter.arxiv_id}</span>)
      </p>
      {frontmatter.facets && frontmatter.facets.length > 0 && (
        <p class="entry-facets">
          {frontmatter.facets.map((f) => (
            <span class="facet-chip">{f}</span>
          ))}
        </p>
      )}
      <p class="entry-problem">{frontmatter.problem_solved}</p>
    </header>

    <slot />

    <AdoptionList adopted_by={frontmatter.adopted_by} />

    <Lineage
      predecessors={frontmatter.predecessors ?? []}
      successors={frontmatter.successors ?? []}
      prerequisites={frontmatter.prerequisites ?? []}
    />

    <Cite
      paper_title={frontmatter.paper_title}
      introduced_by={frontmatter.introduced_by}
      year={frontmatter.year}
      arxiv_id={frontmatter.arxiv_id}
      paper_url={frontmatter.paper_url}
    />

    <footer class="entry-footer">
      <p>Last verified {frontmatter.last_verified}.</p>
    </footer>
  </article>
</BaseLayout>

<style>
  .entry-header {
    margin: 48px 0 56px;
  }
  .entry-header h1 {
    margin-top: 8px;
    margin-bottom: 24px;
  }
  .entry-meta {
    color: var(--text-soft);
    font-size: var(--t-small);
    margin-bottom: 16px;
  }
  .entry-meta cite { font-style: italic; }
  .arxiv { font-family: var(--mono); font-size: 0.85em; }
  .entry-difficulty {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--text-faint);
    letter-spacing: 0.04em;
    margin: 0 0 16px;
  }
  .entry-facets {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin: 0 0 16px;
  }
  .facet-chip {
    font-size: 0.78rem;
    color: var(--text-soft);
    border: 1px solid var(--border);
    background: transparent;
    padding: 2px 6px;
    border-radius: 2px;
    line-height: 1.4;
  }
  .entry-problem {
    font-size: 1.125rem;
    color: var(--text-soft);
    font-style: italic;
    line-height: 1.6;
  }
  .entry-footer {
    color: var(--text-faint);
    font-size: var(--t-small);
    margin-top: 48px;
    padding-top: 16px;
    border-top: 1px solid var(--border);
  }
</style>
