---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { BASE } from "~/utils/site";
---

<BaseLayout title="Not found" description="That page does not exist.">
  <article class="prose">
    <header class="entry-header">
      <p class="section-eyebrow">404</p>
      <h1>That page is not in the knowledge base.</h1>
      <p class="lede">
        Either it has not been written yet, or the URL is wrong. Try <a href={`${BASE}/`}>the home page</a>
        or browse <a href={`${BASE}/about/`}>the methodology</a> for the closed-model policy.
      </p>
    </header>
  </article>
</BaseLayout>

<style>
  .entry-header { margin: 80px 0; }
  .entry-header h1 { font-size: 2rem; margin: 12px 0 24px; }
  .lede { font-size: 1.125rem; color: var(--text-soft); line-height: 1.55; }
</style>
