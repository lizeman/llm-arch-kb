---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { sortChronological, isoMonth } from "~/utils/chronological-sort";
import { CATEGORY_LABELS } from "~/utils/adoption-graph";
import { ARCH_SLOTS, displayArch, type ArchKey } from "~/utils/architecture";
import { BASE, slugTail } from "~/utils/site";
import { TECHNIQUE_CATEGORIES } from "~/content/config";
import ArchMatrix, { type ArchRow } from "~/components/compare/ArchMatrix";
import HeatmapMatrix from "~/components/compare/HeatmapMatrix";
import TechniqueMatrix from "~/components/compare/TechniqueMatrix";
import "~/components/compare/compare.css";

const models = (await getCollection("models")).sort((a, b) =>
  a.data.release_date.localeCompare(b.data.release_date),
);
const techniques = await getCollection("techniques");
const sortedTechniques = sortChronological(techniques);

// ----- Model architecture matrix data ------------------------------------
const archRows: ArchRow[] = models.map((m) => {
  const row: ArchRow = {
    slug: m.slug,
    name: m.data.name,
    organization: m.data.organization,
    release_date: m.data.release_date,
    year: Number(m.data.release_date.slice(0, 4)),
    disclosure: m.data.disclosure_level,
    href: `${BASE}/models/${m.slug}/`,
  };
  for (const s of ARCH_SLOTS) {
    row[s.key] = displayArch(m.data.architecture[s.key as ArchKey] as string | boolean | null);
  }
  return row;
});

const archOrgs = Array.from(new Set(models.map((m) => m.data.organization))).sort();
const archYears = archRows.map((r) => r.year);
const archYearBounds = { min: Math.min(...archYears), max: Math.max(...archYears) };
const archDisclosures = Array.from(new Set(models.map((m) => m.data.disclosure_level))).sort();

// ----- Heatmap data ------------------------------------------------------
const heatmapColumns = TECHNIQUE_CATEGORIES.flatMap((cat) => {
  const items = sortChronological(techniques.filter((t) => t.data.category === cat));
  return items.map((t) => ({
    cat,
    catLabel: CATEGORY_LABELS[cat] ?? cat,
    slug: slugTail(t.slug),
    title: t.data.title,
    abbreviation: t.data.abbreviation,
    href: `${BASE}/${cat}/${slugTail(t.slug)}/`,
    adopted: (t.data.adopted_by ?? []).map((a) => a.model),
  }));
});

const heatmapModels = models.map((m) => ({
  slug: m.slug,
  name: m.data.name,
  organization: m.data.organization,
  year: Number(m.data.release_date.slice(0, 4)),
  disclosure: m.data.disclosure_level,
  href: `${BASE}/models/${m.slug}/`,
}));

const heatmapCategoryOptions = TECHNIQUE_CATEGORIES.filter((c) =>
  heatmapColumns.some((col) => col.cat === c),
).map((c) => ({ key: c, label: CATEGORY_LABELS[c] ?? c }));

const heatmapOrgOptions = Array.from(new Set(models.map((m) => m.data.organization)))
  .sort()
  .map((o) => ({ key: o, label: o }));

// ----- Technique matrix data --------------------------------------------
const techRows = sortedTechniques.map((t) => ({
  slug: slugTail(t.slug),
  category: t.data.category,
  categoryLabel: CATEGORY_LABELS[t.data.category] ?? t.data.category,
  title: t.data.title,
  abbreviation: t.data.abbreviation,
  href: `${BASE}/${t.data.category}/${slugTail(t.slug)}/`,
  year: t.data.year,
  month: t.data.month ?? null,
  yearLabel: isoMonth(t.data.year, t.data.month),
  status: t.data.status,
  adopters: t.data.adopted_by?.length ?? 0,
  summary: t.data.summary,
}));

const techCategoryOptions = Array.from(new Set(techRows.map((t) => t.category)))
  .sort()
  .map((c) => ({ key: c, label: CATEGORY_LABELS[c] ?? c }));
const techStatusOptions = Array.from(new Set(techRows.map((t) => t.status)))
  .sort()
  .map((s) => ({ key: s, label: s }));
const techYears = techRows.map((t) => t.year);
const techYearBounds = { min: Math.min(...techYears), max: Math.max(...techYears) };
---

<BaseLayout
  title="Compare"
  description="Side-by-side architecture matrix for every documented production model in the knowledge base."
>
  <article class="prose-wide">
    <header class="entry-header">
      <p class="section-eyebrow">Browse</p>
      <h1>Compare</h1>
      <p class="lede">
        Architecture slot by architecture slot, every documented model in the knowledge base.
        Empty cells (—) mean the choice was not publicly disclosed, per the
        <a href={`${BASE}/about/`}>citation policy</a>.
      </p>
    </header>

    <h2>Model adoption matrix</h2>
    <p class="table-lede">
      Each row is a production model with public architecture documentation. Each column is a
      design slot. Click a column header to sort; chips above filter by organization, disclosure
      level, or release-year range.
    </p>

    <ArchMatrix
      client:visible
      rows={archRows}
      slots={[...ARCH_SLOTS]}
      organizations={archOrgs}
      disclosures={archDisclosures}
      yearBounds={archYearBounds}
    />

    <h2 class="mt-section">Model × technique adoption matrix</h2>
    <p class="table-lede">
      Rows are models, columns are techniques grouped by category. A filled marker means the
      model's spec sheet cites that technique. Hover a cell to highlight its row and column.
      Select 2–6 models below to compare them side-by-side.
    </p>

    <HeatmapMatrix
      client:visible
      models={heatmapModels}
      columns={heatmapColumns}
      categoryOptions={heatmapCategoryOptions}
      organizationOptions={heatmapOrgOptions}
    />

    <h2 class="mt-section">Technique matrix</h2>
    <p class="table-lede">
      Each row is a documented technique. The "adopters" column counts how many of our
      spec-sheet'd models cite the technique. Click any column header to sort.
    </p>

    <TechniqueMatrix
      client:visible
      rows={techRows}
      categories={techCategoryOptions}
      statuses={techStatusOptions}
      yearBounds={techYearBounds}
    />

    <h2 class="mt-section">Coverage notes</h2>
    <p>
      v1 ship covers the open / documented frontier model families
      (<strong>Llama, OLMo, DeepSeek, Gemma</strong>); the v2 ship plans to extend to
      <strong>Kimi, MiniMax, GLM</strong> with the same disclosure standard.
      Closed-frontier families (GPT-*, Claude, Gemini) are intentionally absent — see the
      <a href={`${BASE}/about/`}>methodology</a> for why.
    </p>
  </article>
</BaseLayout>

<style is:global>
  /* Inline cell helpers for the TanStack islands.
     Kept global so the Solid-rendered subtree can pick them up. */
  .cmp-row-org {
    display: block;
    color: var(--text-faint);
    font-size: 0.78rem;
    font-weight: 400;
    margin-top: 2px;
  }
  .cmp-mono {
    font-family: var(--mono);
    color: var(--text-soft);
    font-size: 0.85rem;
  }
  .cmp-cat {
    font-family: var(--mono);
    color: var(--accent);
    font-size: 0.85rem;
  }
  .cmp-abbr {
    display: block;
    font-family: var(--mono);
    color: var(--text-faint);
    font-size: 0.75rem;
    margin-top: 2px;
    letter-spacing: 0.02em;
    font-weight: 400;
  }
  .cmp-adopters {
    font-family: var(--mono);
    color: var(--text-soft);
    font-size: 0.85rem;
  }
  .cmp-summary {
    white-space: normal;
    display: inline-block;
    max-width: 320px;
    color: var(--text-soft);
    line-height: 1.45;
    font-size: 0.9375rem;
  }
</style>

<style>
  .entry-header { margin: 48px 0 56px; }
  .entry-header h1 { margin: 8px 0 24px; }
  .lede { color: var(--text-soft); font-size: 1.125rem; line-height: 1.55; }
  h2 { margin-top: 32px; }
  .mt-section { margin-top: 64px; }
  .table-lede {
    color: var(--text-soft);
    margin-bottom: 24px;
  }
</style>
