---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { sortChronological, isoMonth } from "~/utils/chronological-sort";
import { CATEGORY_LABELS } from "~/utils/adoption-graph";
import { ARCH_SLOTS, displayArch, type ArchKey } from "~/utils/architecture";
import { BASE, slugTail } from "~/utils/site";
import { TECHNIQUE_CATEGORIES } from "~/content/config";

const models = (await getCollection("models")).sort((a, b) =>
  a.data.release_date.localeCompare(b.data.release_date),
);
const techniques = await getCollection("techniques");
const sortedTechniques = sortChronological(techniques);

// Heat-map: model x technique adoption matrix.
// Columns grouped by category, ordered chronologically within group.
const heatmapColumns = TECHNIQUE_CATEGORIES.flatMap((cat) => {
  const items = sortChronological(techniques.filter((t) => t.data.category === cat));
  return items.map((t) => ({
    cat,
    catLabel: CATEGORY_LABELS[cat] ?? cat,
    slug: slugTail(t.slug),
    title: t.data.title,
    abbreviation: t.data.abbreviation,
    adoptedSet: new Set((t.data.adopted_by ?? []).map((a) => a.model)),
  }));
});
const heatmapGroups = TECHNIQUE_CATEGORIES.map((cat) => ({
  cat,
  label: CATEGORY_LABELS[cat] ?? cat,
  count: heatmapColumns.filter((c) => c.cat === cat).length,
})).filter((g) => g.count > 0);
---

<BaseLayout
  title="Compare"
  description="Side-by-side architecture matrix for every documented production model in the knowledge base."
>
  <article class="prose-wide">
    <header class="entry-header">
      <p class="section-eyebrow">Browse</p>
      <h1>Compare</h1>
      <p class="lede">
        Architecture slot by architecture slot, every documented model in the knowledge base.
        Empty cells (—) mean the choice was not publicly disclosed, per the
        <a href={`${BASE}/about/`}>citation policy</a>.
      </p>
    </header>

    <h2>Model adoption matrix</h2>
    <p class="table-lede">
      Each row is a production model with public architecture documentation. Each column is a
      design slot. Cells repeat the model's disclosed choice; the interactive
      <a href={`${BASE}/compare/`}>sortable variant</a> is on the v2 roadmap.
    </p>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th scope="col">Model</th>
            {ARCH_SLOTS.map((s) => <th scope="col">{s.shortLabel}</th>)}
          </tr>
        </thead>
        <tbody>
          {models.map((m) => (
            <tr>
              <th scope="row">
                <a href={`${BASE}/models/${m.slug}/`}>{m.data.name}</a>
                <span class="org">{m.data.organization}</span>
              </th>
              {ARCH_SLOTS.map((s) => (
                <td>{displayArch(m.data.architecture[s.key as ArchKey] as string | boolean | null)}</td>
              ))}
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <h2 class="mt-section">Model × technique adoption matrix</h2>
    <p class="table-lede">
      Rows are models in chronological order; columns are techniques grouped by category,
      ordered chronologically within each group. A filled marker means the model's spec sheet
      cites that technique. Hover a column header for the full technique name.
    </p>

    <div class="heatmap-wrap">
      <table class="heatmap">
        <caption class="visually-hidden">Model × technique adoption matrix</caption>
        <thead>
          <tr class="heatmap-grouprow">
            <th scope="col" class="heatmap-corner" rowspan="2">Model</th>
            {heatmapGroups.map((g, i) => (
              <th
                scope="colgroup"
                colspan={g.count}
                class:list={["heatmap-group", { "group-sep": i > 0 }]}
              >{g.label}</th>
            ))}
          </tr>
          <tr>
            {heatmapColumns.map((c, i) => {
              const prev = heatmapColumns[i - 1];
              const newGroup = !prev || prev.cat !== c.cat;
              return (
                <th
                  scope="col"
                  class:list={["heatmap-col", { "group-sep": newGroup && i > 0 }]}
                  title={c.title}
                >
                  <a href={`${BASE}/${c.cat}/${c.slug}/`}>{c.abbreviation}</a>
                </th>
              );
            })}
          </tr>
        </thead>
        <tbody>
          {models.map((m) => (
            <tr>
              <th scope="row" class="heatmap-rowhead">
                <a href={`${BASE}/models/${m.slug}/`}>{m.data.name}</a>
              </th>
              {heatmapColumns.map((c, i) => {
                const prev = heatmapColumns[i - 1];
                const newGroup = !prev || prev.cat !== c.cat;
                const hit = c.adoptedSet.has(m.slug);
                return (
                  <td class:list={["heatmap-cell", { "group-sep": newGroup && i > 0 }]}>
                    {hit ? (
                      <span class="dot" aria-label={`${m.data.name} adopts ${c.title}`}>●</span>
                    ) : (
                      <span class="empty-cell" aria-hidden="true"></span>
                    )}
                  </td>
                );
              })}
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div class="heatmap-cards">
      {models.map((m) => {
        const adopted = heatmapColumns.filter((c) => c.adoptedSet.has(m.slug));
        return (
          <section class="heatmap-card">
            <h3>
              <a href={`${BASE}/models/${m.slug}/`}>{m.data.name}</a>
              <span class="card-org">{m.data.organization}</span>
            </h3>
            {adopted.length === 0 ? (
              <p class="card-empty">No documented adoptions yet.</p>
            ) : (
              <ul class="card-chips">
                {adopted.map((c) => (
                  <li>
                    <a class="chip-link" href={`${BASE}/${c.cat}/${c.slug}/`} title={c.title}>
                      {c.abbreviation}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </section>
        );
      })}
    </div>

    <h2 class="mt-section">Technique matrix</h2>
    <p class="table-lede">
      Each row is a documented technique in the knowledge base. The "adopters" column counts
      how many of our spec-sheet'd models cite the technique.
    </p>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th scope="col">Year</th>
            <th scope="col">Category</th>
            <th scope="col">Technique</th>
            <th scope="col">Status</th>
            <th scope="col">Adopters</th>
            <th scope="col">Summary</th>
          </tr>
        </thead>
        <tbody>
          {sortedTechniques.map((t) => (
            <tr>
              <td class="year">{isoMonth(t.data.year, t.data.month)}</td>
              <td class="cat">{CATEGORY_LABELS[t.data.category] ?? t.data.category}</td>
              <th scope="row">
                <a href={`${BASE}/${t.data.category}/${slugTail(t.slug)}/`}>{t.data.title}</a>
                <span class="abbr">{t.data.abbreviation}</span>
              </th>
              <td class="status">{t.data.status}</td>
              <td class="adopters">{t.data.adopted_by?.length ?? 0}</td>
              <td class="summary">{t.data.summary}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <h2 class="mt-section">Coverage notes</h2>
    <p>
      v1 ship covers the open / documented frontier model families
      (<strong>Llama, OLMo, DeepSeek, Gemma</strong>); the v2 ship plans to extend to
      <strong>Kimi, MiniMax, GLM</strong> with the same disclosure standard.
      Closed-frontier families (GPT-*, Claude, Gemini) are intentionally absent — see the
      <a href={`${BASE}/about/`}>methodology</a> for why.
    </p>
  </article>
</BaseLayout>

<style>
  .entry-header { margin: 48px 0 56px; }
  .entry-header h1 { margin: 8px 0 24px; }
  .lede { color: var(--text-soft); font-size: 1.125rem; line-height: 1.55; }

  h2 { margin-top: 32px; }
  .mt-section { margin-top: 64px; }

  .table-lede {
    color: var(--text-soft);
    margin-bottom: 24px;
  }

  .table-wrap {
    overflow-x: auto;
    margin: 24px 0;
    border: 1px solid var(--border);
    border-radius: 2px;
  }

  table {
    margin: 0;
    border-collapse: collapse;
    font-size: var(--t-small);
    min-width: 100%;
  }

  th, td {
    padding: 10px 14px;
    border-bottom: 1px solid var(--border);
    vertical-align: top;
    text-align: left;
    white-space: nowrap;
  }
  thead th {
    background: var(--bg-soft);
    color: var(--text);
    font-family: var(--mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    position: sticky;
    top: 0;
  }
  tbody th {
    background: transparent;
    text-align: left;
    font-weight: 600;
  }
  tbody th a { color: var(--text); text-decoration: none; }
  tbody th a:hover { color: var(--accent); text-decoration: underline; }
  .org {
    display: block;
    color: var(--text-faint);
    font-size: 0.78rem;
    font-weight: 400;
    margin-top: 2px;
  }
  .year {
    font-family: var(--mono);
    color: var(--text-soft);
    font-size: 0.78rem;
    white-space: nowrap;
  }
  .cat {
    font-family: var(--mono);
    color: var(--accent);
    font-size: 0.78rem;
    white-space: nowrap;
  }
  .abbr {
    display: block;
    font-family: var(--mono);
    color: var(--text-faint);
    font-size: 0.72rem;
    margin-top: 2px;
    letter-spacing: 0.02em;
    font-weight: 400;
  }
  .status {
    font-family: var(--mono);
    color: var(--text-soft);
    font-size: 0.78rem;
    white-space: nowrap;
  }
  .adopters {
    font-family: var(--mono);
    color: var(--text-soft);
    font-size: 0.78rem;
    text-align: center;
  }
  .summary {
    white-space: normal;
    max-width: 320px;
    color: var(--text-soft);
    line-height: 1.45;
    font-size: 0.85rem;
  }

  /* Heat-map (model x technique) */
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  .heatmap-wrap {
    overflow-x: auto;
    margin: 24px 0;
    border: 1px solid var(--border);
    border-radius: 2px;
  }
  .heatmap {
    border-collapse: collapse;
    font-size: 0.78rem;
  }
  .heatmap th, .heatmap td {
    padding: 6px 8px;
    border-bottom: 1px solid var(--border);
    text-align: center;
    vertical-align: middle;
    white-space: nowrap;
  }
  .heatmap .heatmap-group {
    background: var(--bg-soft);
    font-family: var(--mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-soft);
    border-bottom: 1px solid var(--border);
    padding: 6px 10px;
  }
  .heatmap .heatmap-corner {
    background: var(--bg-soft);
    text-align: left;
    color: var(--text);
    font-family: var(--mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    border-right: 1px solid var(--border);
    position: sticky;
    left: 0;
    z-index: 2;
  }
  .heatmap .heatmap-col {
    background: var(--bg-soft);
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--text-soft);
    font-weight: 400;
    padding: 8px 6px;
  }
  .heatmap .heatmap-col a {
    color: var(--text-soft);
    text-decoration: none;
  }
  .heatmap .heatmap-col a:hover { color: var(--accent); text-decoration: underline; }
  .heatmap .heatmap-rowhead {
    background: var(--bg);
    text-align: left;
    font-weight: 600;
    border-right: 1px solid var(--border);
    position: sticky;
    left: 0;
    z-index: 1;
    padding-right: 14px;
  }
  .heatmap .heatmap-rowhead a {
    color: var(--text);
    text-decoration: none;
  }
  .heatmap .heatmap-rowhead a:hover { color: var(--accent); text-decoration: underline; }
  .heatmap .heatmap-cell { padding: 6px 10px; }
  .heatmap .dot {
    color: var(--accent);
    font-size: 0.85rem;
    line-height: 1;
  }
  .heatmap .empty-cell {
    display: inline-block;
    width: 4px;
    height: 1px;
  }
  .heatmap .group-sep { border-left: 1px solid var(--border); }

  /* Card layout below desktop */
  .heatmap-cards { display: none; }
  @media (max-width: 880px) {
    .heatmap-wrap { display: none; }
    .heatmap-cards { display: block; margin: 24px 0; }
    .heatmap-card {
      padding: 16px 0;
      border-bottom: 1px solid var(--border);
    }
    .heatmap-card:last-child { border-bottom: none; }
    .heatmap-card h3 {
      margin: 0 0 8px;
      font-size: 1rem;
      font-weight: 600;
    }
    .heatmap-card h3 a {
      color: var(--text);
      text-decoration: none;
    }
    .heatmap-card h3 a:hover { color: var(--accent); text-decoration: underline; }
    .card-org {
      display: block;
      color: var(--text-faint);
      font-size: 0.78rem;
      font-weight: 400;
      margin-top: 2px;
    }
    .card-empty {
      color: var(--text-faint);
      font-size: var(--t-small);
      font-style: italic;
      margin: 0;
    }
    .card-chips {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }
    .chip-link {
      display: inline-block;
      border: 1px solid var(--border);
      border-radius: 999px;
      padding: 2px 10px;
      font-family: var(--mono);
      font-size: 0.7rem;
      letter-spacing: 0.02em;
      color: var(--text-soft);
      text-decoration: none;
    }
    .chip-link:hover { color: var(--accent); border-color: var(--accent); }
  }
</style>
