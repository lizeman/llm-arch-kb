---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import { FACETS, FACET_LABELS, FACET_DESCRIPTIONS, type Facet } from "~/utils/facets";
import { BASE } from "~/utils/site";

const all = await getCollection("techniques");

const counts = new Map<Facet, number>();
for (const f of FACETS) counts.set(f, 0);
for (const t of all) {
  const facets = (t.data.facets ?? []) as Facet[];
  for (const f of facets) {
    if (counts.has(f)) counts.set(f, (counts.get(f) ?? 0) + 1);
  }
}

const rows = FACETS.map((f) => ({
  slug: f,
  label: FACET_LABELS[f],
  description: FACET_DESCRIPTIONS[f],
  count: counts.get(f) ?? 0,
}));
---

<BaseLayout
  title="Facets"
  description="Cross-cutting tags that group techniques by what they optimize for — efficiency, stability, KV cache, and others."
>
  <article class="prose">
    <header class="facets-header">
      <p class="section-eyebrow">Browse</p>
      <h1>Facets</h1>
      <p class="lede">
        Each technique can carry one or more facets — orthogonal axes that cut across the
        positional / norm / attention / FFN taxonomy. Use them to find every entry that
        targets, say, KV-cache shrinkage or training stability.
      </p>
    </header>

    <ul class="facet-list">
      {rows.map((r) => (
        <li>
          <a href={`${BASE}/facets/${r.slug}/`}>
            <div class="facet-list__title">
              <strong>{r.label}</strong>
              <span class="count">{r.count} {r.count === 1 ? "entry" : "entries"}</span>
            </div>
            <p class="facet-list__desc">{r.description}</p>
          </a>
        </li>
      ))}
    </ul>
  </article>
</BaseLayout>

<style>
  .facets-header { margin: 48px 0 56px; }
  .facets-header h1 { margin: 8px 0 24px; }
  .lede {
    font-size: 1.125rem;
    color: var(--text-soft);
    line-height: 1.6;
  }
  .facet-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .facet-list li {
    border-bottom: 1px solid var(--border);
  }
  .facet-list a {
    display: block;
    padding: 20px 0;
    color: var(--text);
    text-decoration: none;
  }
  .facet-list a:hover .facet-list__title strong { color: var(--accent); }
  .facet-list__title {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 4px;
  }
  .facet-list__title strong { font-size: 1.125rem; font-weight: 600; }
  .count {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--text-faint);
    letter-spacing: 0.04em;
  }
  .facet-list__desc {
    margin: 0;
    color: var(--text-soft);
    font-size: var(--t-small);
    line-height: 1.55;
  }
</style>
