---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import { BASE, slugTail } from "~/utils/site";

export async function getStaticPaths() {
  const paths = await getCollection("paths");
  return paths.map((p) => ({
    params: { slug: p.slug },
    props: { entry: p },
  }));
}

type Props = { entry: Awaited<ReturnType<typeof getCollection<"paths">>>[number] };
const { entry } = Astro.props as Props;
const { Content } = await entry.render();

const techniques = await getCollection("techniques");
// Look up by tail slug to keep authoring simple.
const lookup = new Map<string, { title: string; abbreviation: string; category: string; summary: string }>();
for (const t of techniques) {
  lookup.set(slugTail(t.slug), {
    title: t.data.title,
    abbreviation: t.data.abbreviation,
    category: t.data.category,
    summary: t.data.summary,
  });
}

const steps = entry.data.techniques
  .map((s) => {
    const meta = lookup.get(s);
    return meta ? { slug: s, ...meta } : null;
  })
  .filter((x): x is NonNullable<typeof x> => x !== null);

const DIFFICULTY_LABEL: Record<string, string> = {
  intro: "Intro",
  intermediate: "Intermediate",
  advanced: "Advanced",
};
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <article class="prose">
    <header class="path-header">
      <p class="section-eyebrow">
        <a href={`${BASE}/paths/`}>Learning path</a>
        &nbsp;·&nbsp;{DIFFICULTY_LABEL[entry.data.difficulty] ?? entry.data.difficulty}
      </p>
      <h1>{entry.data.title}</h1>
      <p class="lede">{entry.data.description}</p>
    </header>

    <section class="path-intro">
      <Content />
    </section>

    <ol class="step-list">
      {steps.map((s, idx) => (
        <li>
          <a href={`${BASE}/${s.category}/${s.slug}/`}>
            <span class="step-num">{idx + 1}</span>
            <span class="step-body">
              <span class="step-title">
                <strong>{s.title}</strong>
                <span class="abbr">{s.abbreviation}</span>
              </span>
              <span class="step-summary">{s.summary}</span>
            </span>
          </a>
        </li>
      ))}
    </ol>
  </article>
</BaseLayout>

<style>
  .path-header { margin: 48px 0 32px; }
  .path-header h1 { margin: 8px 0 16px; }
  .lede {
    font-size: 1.125rem;
    color: var(--text-soft);
    line-height: 1.6;
  }
  .path-intro {
    margin: 24px 0 40px;
    color: var(--text-soft);
    line-height: 1.7;
  }
  .step-list {
    list-style: none;
    counter-reset: step;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--border);
  }
  .step-list li { border-bottom: 1px solid var(--border); }
  .step-list a {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 18px 0;
    color: var(--text);
    text-decoration: none;
  }
  .step-list a:hover .step-title strong { color: var(--accent); }
  .step-num {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--text-faint);
    width: 1.5em;
    flex-shrink: 0;
    padding-top: 2px;
  }
  .step-body {
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex: 1;
  }
  .step-title {
    display: flex;
    align-items: baseline;
    gap: 12px;
    flex-wrap: wrap;
  }
  .step-title strong { font-size: 1.0625rem; font-weight: 600; }
  .abbr {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--text-faint);
    letter-spacing: 0.04em;
  }
  .step-summary {
    color: var(--text-soft);
    font-size: var(--t-small);
    line-height: 1.55;
  }
</style>
